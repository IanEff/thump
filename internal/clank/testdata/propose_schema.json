{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ianeff/thump/internal/clank/propose-input",
  "properties": {
    "failureClass": {
      "type": "string",
      "enum": [
        "dependency_saturation",
        "traffic_shift",
        "resource_exhaustion",
        "redundancy_degraded",
        "service_failure"
      ]
    },
    "hypotheses": {
      "items": {
        "properties": {
          "name": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "name",
          "weight"
        ]
      },
      "type": "array"
    },
    "proposals": {
      "items": {
        "properties": {
          "id": {
            "type": "string"
          },
          "contractRef": {
            "type": "string"
          },
          "confidence": {
            "type": "number"
          },
          "citations": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "description": "the evidence backing this candidate: the exact keys shown as [cite: \u003ckey\u003e] in this run's tool results, repeated verbatim — never a description or paraphrase of the value"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "contractRef",
          "citations"
        ]
      },
      "type": "array"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "failureClass",
    "proposals"
  ]
}
