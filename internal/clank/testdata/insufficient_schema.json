{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ianeff/thump/internal/clank/insufficient-input",
  "properties": {
    "reason": {
      "type": "string"
    },
    "failureClass": {
      "type": "string",
      "enum": [
        "dependency_saturation",
        "traffic_shift",
        "resource_exhaustion",
        "unknown",
        "redundancy_degraded",
        "service_failure"
      ],
      "description": "the failure class your evidence supports, if you reached a diagnosis — recorded even though no action is proposed"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "reason"
  ]
}
